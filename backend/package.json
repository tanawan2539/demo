{
  "name": "@starter/backend",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile=server",
    "start": "bun src/index.ts",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --write src/",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:apply-room-tables": "bun run src/db/run-room-migration.ts",
    "db:seed": "bun src/db/seed.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "axios": "^1.14.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "knex": "^3.2.8",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
